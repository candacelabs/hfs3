# === hfs3 configuration ===

# REQUIRED: S3 bucket for mirrored repos
HFS3_S3_BUCKET=your-bucket-name

# Optional: key prefix within the bucket (default: hfs3-mirror)
# HFS3_S3_PREFIX=hfs3-mirror

# Optional: HuggingFace auth token (needed for gated repos like Llama)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Optional: AWS region (uses SDK default / AWS_DEFAULT_REGION if unset)
# AWS_REGION=us-east-1
